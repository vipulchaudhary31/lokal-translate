{
  "compilerOptions": {
    "esModuleInterop": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": ["DOM", "ES2020"],
    "module": "ES2020",
    "moduleResolution": "Node",
    "strict": true,
    "types": ["@figma/plugin-typings"],
    "skipLibCheck": true
  },
  "include": ["./src/**/*"]
}
